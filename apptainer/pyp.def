Bootstrap: docker
From: mambaorg/micromamba:debian12-slim
IncludeCmd: no

%help
	TODO

%files

	bin/* /opt/pyp/bin/
	config/ /opt/pyp
	src/ /opt/pyp
	requirements.txt /opt/pyp
	LICENSE  /opt/pyp
	nextpyp.toml /opt/pyp
 	pyproject.toml /opt/pyp
	README.rst /opt/pyp
	tests/ /opt/pyp
	external/ /opt/pyp
	/nfs/bartesaghilab/ab690/nextpyp/models /opt/pyp/external
	/nfs/bartesaghilab/ab690/nextpyp/pyp/external/tomodrgn /opt/pyp/external
	../ResMap/ /opt/pyp/external
	../AreTomo2/ /opt/pyp/external
	../MotionCor3/ /opt/pyp/external
	../AreTomo3/ /opt/pyp/external

%environment

	# this needs to be set here because it's the first thing pyp does, even before initializing env vars
	export PYP_DIR=/opt/pyp

	# somehow, after all that installation trouble, conda *STILL* doesn't manage to make the packages available to python
	# probably because we don't have any way to "activate" the conda environment inside the container
	# so we'll have to do it manually... sigh
	export LD_LIBRARY_PATH=/opt/conda/envs/pyp/lib:/lib/x86_64-linux-gnu:/usr/local/lib:$LD_LIBRARY_PATH
	export PATH=$PYP_DIR/bin:/opt/conda/envs/pyp/bin:/usr/local/bin:$PATH
	export PYTHONPATH=/opt/pyp/src
	export IMOD_DIR=/opt/IMOD
	export PATH=$PATH:$IMOD_DIR/bin
	export PATH=$PATH:/opt/potrace-1.16.linux-x86_64
	export XDG_CACHE_HOME=/tmp

%post
	
	# remove pyp's .git directory to save space
	rm -rf /opt/pyp/.git

	# install packages required by ETTK
	apt-get -y update
	apt-get install -y make g++ libghc-bzlib-dev libfftw3-dev vim nano imagemagick libtiff-dev file wget git xvfb

	# relion specific requirements
	apt-get install -y cmake build-essential mpi-default-bin mpi-default-dev libpng-dev ghostscript libxft-dev

    # remove anything we don't need
    apt clean
    apt autoremove --yes

	# trick IMOD into believing we have version 5 of libtiff
	ln -s /usr/lib/x86_64-linux-gnu/libtiff.so.6 /usr/lib/x86_64-linux-gnu/libtiff.so.5

	# increase ImageMagick resource limits
	sed -i -E 's/name="disk" value=".+"/name="disk" value="32GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="memory" value=".+"/name="memory" value="32GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="width" value=".+"/name="width" value="256KP"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="height" value=".+"/name="heigth" value="256KP"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="map" value=".+"/name="map" value="16GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="area" value=".+"/name="area" value="16GiB"/g' /etc/ImageMagick-6/policy.xml

	dpkg --configure -a
 
	# install all external dependencies from script
	chmod +x /opt/pyp/apptainer/externals.sh
	/bin/bash -lc "source /opt/pyp/apptainer/externals.sh"

    # make a place to build things

	# make fontconfig cache persistent to prevent the infamous warning: "Fontconfig error: No writable cache directories"
	fc-cache -fv

	# Install milopyp
cat << EOF > /root/milopyp.sh

	# cet_pick dependencies
	pip --no-cache-dir install -r /opt/pyp/external/cet_pick/requirements.txt
	pip --no-cache-dir install --extra-index-url https://download.pytorch.org/whl/cu128 torch==2.9.0 torchvision==0.24.0

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/milopyp -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name milopyp python=3.12 -c conda-forge -c pytorch pytorch=2.4.0 torchvision=0.19.0 colored-traceback==0.3.0 overrides==7.7.0 imagesize==1.4.1 h5py==3.15.1 tensorboard==2.20.0

	# run the conda script in the new environment
	chmod +x /root/milopyp.sh
	micromamba run -n milopyp /bin/bash -c "/root/milopyp.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/milopyp.sh

	# Install topaz
cat << EOF > /root/topaz.sh

	# install topaz from source
    cd /opt/pyp/external
    git clone https://github.com/tbepler/topaz.git
    cd topaz
    git checkout v0.3.18
    pip install .
    rm -rf .git/
    cd -

	pip install --pre torch torchvision torchaudio --index-url https://download.pytorch.org/whl/nightly/cu128
	pip install h5py==3.15.1 tqdm==4.67.3
	
	micromamba clean --all --force-pkgs-dirs --yes
	
EOF
	micromamba create --name topaz "python=3.12"

	# run the conda script in the new environment
	chmod +x /root/topaz.sh
	micromamba run -n topaz /bin/bash -c "/root/topaz.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/topaz.sh

	# Install pytom-match-pick
cat << EOF > /root/pytom.sh

	# install the python packages we need

	python -m pip --no-cache-dir install pytom-match-pick==0.8.0
	python -m pip --no-cache-dir install matplotlib seaborn

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/pytom -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name pytom "python=3" -c conda-forge cupy=13.5.1 cuda-version=11.8

	# run the conda script in the new environment
	chmod +x /root/pytom.sh
	micromamba run -n pytom /bin/bash -c "/root/pytom.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/pytom.sh

	# Install tomoDRGN
cat << EOF > /root/tomodrgn.sh

	# install the python packages we need

	micromamba install "pytorch-gpu>=1.11.0" "cudatoolkit>=11.0" -c pytorch
	micromamba install -c conda-forge pandas seaborn scikit-learn encodings
	micromamba install umap-learn notebook -c conda-forge
	pip --no-cache-dir install "ipyvolume>=0.6.0" "pythreejs>=2.4.2" ipython_genutils

	# Clone source code and install
	# git clone --depth=1 https://github.com/bpowell122/tomodrgn.git
	# use custom version
	cd /opt/pyp/external/
	cd tomodrgn
	pip --no-cache-dir install .
	rm -rf .git/

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/tomodrgn -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name tomodrgn "python=3.10" -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/tomodrgn.sh
	micromamba run -n tomodrgn /bin/bash -c "/root/tomodrgn.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/tomodrgn.sh

	rm -rf /opt/pyp/external/tomoDRGN/.git

	# Install cryoCARE
cat << EOF > /root/cryocare.sh

	# install the python packages we need
	
	pip --no-cache-dir install tensorflow-gpu==2.4.0
	pip --no-cache-dir install tifffile==2019.7.26
	pip --no-cache-dir install cryoCARE

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/cryocare -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name cryocare python=3.8 cudnn=8.0 -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/cryocare.sh
	micromamba run -n cryocare /bin/bash -c "/root/cryocare.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/cryocare.sh

	# Install cryoDRGN
cat << EOF > /root/cryodrgn.sh

	# install the python packages we need

	pip --no-cache-dir install cryodrgn

	# change all plots from png to svgz!
	sed -i 's/.png/.svgz/g' /opt/conda/envs/cryodrgn/lib/python3.9/site-packages/cryodrgn/commands/analyze.py

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/cryodrgn -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name cryodrgn python=3.9 -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/cryodrgn.sh
	micromamba run -n cryodrgn /bin/bash -c "/root/cryodrgn.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/cryodrgn.sh

	# Install membrain
cat << EOF > /root/membrain.sh

	# install the python packages we need

	pip --no-cache-dir install membrain-seg

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/membrain -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name membrain python=3.9 -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/membrain.sh
	micromamba run -n membrain /bin/bash -c "/root/membrain.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/membrain.sh

	# Install tardis
cat << EOF > /root/tardis.sh

	# install the python packages we need

	pip --no-cache-dir install tardis-em==0.3.19

	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/tardis -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name tardis python=3.11 -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/tardis.sh
	micromamba run -n tardis /bin/bash -c "/root/tardis.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/tardis.sh

	# Install IsoNet
cat << EOF > /root/isonet.sh

	# install the python packages we need

	cd /opt/pyp/external
	git clone --depth=1 https://github.com/IsoNet-cryoET/IsoNet.git
	cd IsoNet
	rm -rf .git

	pip --no-cache-dir install tensorflow-gpu==2.10.0
	pip --no-cache-dir install nvidia-tensorrt
	pip --no-cache-dir install -r requirements.txt
	pip --no-cache-dir install --upgrade numpy==1.23.4

	micromamba clean --all --force-pkgs-dirs --yes
	
	cd -
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/isonet -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name isonet python=3.9 cudatoolkit=11.2 cudnn=8.1 -c conda-forge

	# run the conda script in the new environment
	chmod +x /root/isonet.sh
	micromamba run -n isonet /bin/bash -c "/root/isonet.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/isonet.sh

	cd /opt/pyp/external
	git clone --depth=1 https://github.com/IsoNet-cryoET/IsoNet2.git
	cd IsoNet2
	rm -rf .git

	# Install IsoNet2
cat << EOF > /root/isonet2.sh

	# install the python packages we need
	micromamba clean --all --force-pkgs-dirs --yes
	
	cd /opt/pyp/external
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/isonet2 -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name isonet2 --file isonet2_environment.yml

	# run the conda script in the new environment
	chmod +x /root/isonet2.sh
	micromamba run -n isonet2 /bin/bash -c "/root/isonet2.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/isonet2.sh

	# Install WarpTools
cat << EOF > /root/warpem.sh
	micromamba update warp -c warpem -c nvidia/label/cuda-11.8.0 -c pytorch -c conda-forge
	micromamba clean --all --force-pkgs-dirs --yes
	
	rm -rf /tmp/env.tar
	conda-pack -p /opt/conda/envs/warp -o /tmp/env.tar && \
		mkdir -p /venv && cd /venv && tar xf /tmp/env.tar && \
		rm /tmp/env.tar
	/venv/bin/conda-unpack
EOF
	micromamba create --name warp warp=2.0.0 -c warpem -c nvidia/label/cuda-11.8.0 -c pytorch -c conda-forge
	
	chmod +x /root/warpem.sh
	micromamba run -n warp /bin/bash -c "/root/warpem.sh > /proc/$$/fd/1 2>&1"
	rm -rf /root/warpem.sh

	# remove nvidia artifacts to save space
	rm -rf /opt/nvidia

%startscript

%apprun binds
