Bootstrap: docker
From: debian:12-slim
IncludeCmd: no

%help
	TODO

%files

	bin/* /opt/pyp/bin/
	config/ /opt/pyp
	src/ /opt/pyp
	requirements.txt /opt/pyp
	LICENSE  /opt/pyp
	nextpyp.toml /opt/pyp
 	pyproject.toml /opt/pyp
	README.rst /opt/pyp
	tests/ /opt/pyp
	external/ /opt/pyp
	/nfs/bartesaghilab/ab690/nextpyp/models /opt/pyp/external
	/nfs/bartesaghilab/ab690/nextpyp/pyp/external/tomodrgn /opt/pyp/external
	../ResMap/ /opt/pyp/external
	../AreTomo2/ /opt/pyp/external
	../MotionCor3/ /opt/pyp/external
	../AreTomo3/ /opt/pyp/external

%environment

	# this needs to be set here because it's the first thing pyp does, even before initializing env vars
	export PYP_DIR=/opt/pyp

	# somehow, after all that installation trouble, conda *STILL* doesn't manage to make the packages available to python
	# probably because we don't have any way to "activate" the conda environment inside the container
	# so we'll have to do it manually... sigh
	export LD_LIBRARY_PATH=/opt/conda/envs/pyp/lib:/lib/x86_64-linux-gnu:/usr/local/lib:$LD_LIBRARY_PATH
	export PATH=$PYP_DIR/bin:/opt/conda/envs/pyp/bin:/usr/local/bin:$PATH
	export PYTHONPATH=/opt/pyp/src
	export IMOD_DIR=/opt/IMOD
	export PATH=$PATH:$IMOD_DIR/bin
	export PATH=$PATH:/opt/potrace-1.16.linux-x86_64
	export XDG_CACHE_HOME=/tmp

%post
	
	# remove pyp's .git directory to save space
	rm -rf /opt/pyp/.git

	# install packages required by ETTK
	apt-get -y update
	apt-get install -y make g++ libghc-bzlib-dev libfftw3-dev vim nano imagemagick libtiff-dev file wget git xvfb

	# relion specific requirements
	apt-get install -y cmake build-essential mpi-default-bin mpi-default-dev libpng-dev ghostscript libxft-dev

    # remove anything we don't need
    apt clean
    apt autoremove --yes

	# trick IMOD into believing we have version 5 of libtiff
	ln -s /usr/lib/x86_64-linux-gnu/libtiff.so.6 /usr/lib/x86_64-linux-gnu/libtiff.so.5

	# increase ImageMagick resource limits
	sed -i -E 's/name="disk" value=".+"/name="disk" value="32GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="memory" value=".+"/name="memory" value="32GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="width" value=".+"/name="width" value="256KP"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="height" value=".+"/name="heigth" value="256KP"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="map" value=".+"/name="map" value="16GiB"/g' /etc/ImageMagick-6/policy.xml
	sed -i -E 's/name="area" value=".+"/name="area" value="16GiB"/g' /etc/ImageMagick-6/policy.xml

	dpkg --configure -a
 
	# install all external dependencies from script
	chmod +x /opt/pyp/apptainer/externals.sh
	/bin/bash -lc "source /opt/pyp/apptainer/externals.sh"

    # make a place to build things
    mkdir -p /build

    # install pixi
    pixi_version=0.63.2
    wget "https://github.com/prefix-dev/pixi/releases/download/v$pixi_version/pixi-x86_64-unknown-linux-musl.tar.gz" -O "/build/pixi.tar.gz"
    mkdir -p "/build/pixi_tar"
    tar -xvf "/build/pixi.tar.gz" -C "/build/pixi_tar"
    chmod +x "/build/pixi_tar/pixi"
    mv "/build/pixi_tar/pixi" "/usr/bin/pixi"

    # configure pixi to save the global environment somewhere persistent
    # (ie, not the home folder)
    PIXI_HOME=/opt/pixi/env
    export PIXI_HOME
    echo "export PIXI_HOME=$PIXI_HOME" >> "$APPTAINER_ENVIRONMENT"
    mkdir -p "$PIXI_HOME"

    # configure the pixi cache
    PIXI_CACHE_DIR="$PIXI_HOME/cache"
    export PIXI_CACHE_DIR
    mkdir -p "$PIXI_CACHE_DIR"

    RATTLER_CACHE_DIR="$PIXI_HOME/rattler"
    export RATTLER_CACHE_DIR
    mkdir -p "$RATTLER_CACHE_DIR"

    # create the global environment
    PIXI_ENV_NEXTPYP=nextpyp
    export PIXI_ENV_NEXTPYP
    echo "export PIXI_ENV_NEXTPYP=$PIXI_ENV_NEXTPYP" >> "$APPTAINER_ENVIRONMENT"
    pixi global install \
        --environment "$PIXI_ENV_NEXTPYP" \
        --channel "https://conda.modular.com/max-nightly" \
        --channel "conda-forge" \
        "python=3.13.*" \
        "mojo-compiler==0.25.7.0" \
		--with htop \
		--with conda-pack \
		--with "libstdcxx-ng==15.2.0" \
		"pip" \
		&& ${PIXI_HOME}/envs/${PIXI_ENV_NEXTPYP}/bin/python -m pip install -r /opt/pyp/requirements.txt

    # add pixi global environment bin to the path
    PATH="$PIXI_HOME/bin":/usr/local/bin:/usr/bin:/bin
    export PATH
    echo "export PATH=$PATH" >> "$APPTAINER_ENVIRONMENT"

	# make fontconfig cache persistent to prevent the infamous warning: "Fontconfig error: No writable cache directories"
	fc-cache -fv

	# install all pixi-managed environments from script
	chmod +x /opt/pyp/apptainer/pixi-envs.sh
	/bin/bash -lc "source /opt/pyp/apptainer/pixi-envs.sh"

    # pixi is no longer needed
    rm -rf "$PIXI_CACHE_DIR"
    rm -rf "$RATTLER_CACHE_DIR"
    rm -rf "/usr/bin/pixi"

	# remove nvidia artifacts to save space
	rm -rf /opt/nvidia

%startscript

%apprun binds
